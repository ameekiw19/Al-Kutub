package com.example.al_kutub.data.repository

import com.example.al_kutub.model.ReadingProgress
import com.example.al_kutub.utils.SessionManager
import com.google.gson.Gson
import com.google.gson.reflect.TypeToken
import kotlinx.coroutines.flow.Flow
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.map
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class ReadingProgressRepository @Inject constructor(
    private val sessionManager: SessionManager,
    private val gson: Gson
) {
    
    private val _progressCache = MutableStateFlow<List<ReadingProgress>>(emptyList())
    
    init {
        loadProgressFromStorage()
    }
    
    private fun loadProgressFromStorage() {
        val userId = sessionManager.getUserId() ?: return
        val progressJson = sessionManager.getReadingProgress(userId)
        
        if (!progressJson.isNullOrEmpty()) {
            val type = object : TypeToken<List<ReadingProgress>>() {}.type
            val progressList: List<ReadingProgress> = gson.fromJson(progressJson, type) ?: emptyList()
            _progressCache.value = progressList
        }
    }
    
    private fun saveProgressToStorage() {
        val userId = sessionManager.getUserId() ?: return
        val progressJson = gson.toJson(_progressCache.value)
        sessionManager.saveReadingProgress(userId, progressJson)
    }
    
    suspend fun getProgress(userId: Int, kitabId: Int): ReadingProgress? {
        return _progressCache.value.find { 
            it.userId == userId && it.kitabId == kitabId 
        }
    }
    
    fun getAllProgress(userId: Int): Flow<List<ReadingProgress>> {
        return _progressCache.map { progress ->
            progress.filter { it.userId == userId }
        }
    }
    
    fun getCurrentlyReading(userId: Int): Flow<List<ReadingProgress>> {
        return _progressCache.map { progress ->
            progress.filter { it.userId == userId && !it.isCompleted }
        }
    }
    
    fun getCompletedBooks(userId: Int): Flow<List<ReadingProgress>> {
        return _progressCache.map { progress ->
            progress.filter { it.userId == userId && it.isCompleted }
        }
    }
    
    suspend fun getCurrentlyReadingCount(userId: Int): Int {
        return _progressCache.value.count { it.userId == userId && !it.isCompleted }
    }
    
    suspend fun getCompletedBooksCount(userId: Int): Int {
        return _progressCache.value.count { it.userId == userId && it.isCompleted }
    }
    
    suspend fun getTotalReadingTime(userId: Int): Int {
        return _progressCache.value
            .filter { it.userId == userId }
            .sumOf { it.readingTimeMinutes }
    }
    
    suspend fun saveProgress(progress: ReadingProgress) {
        val currentList = _progressCache.value.toMutableList()
        val existingIndex = currentList.indexOfFirst { 
            it.userId == progress.userId && it.kitabId == progress.kitabId 
        }
        
        if (existingIndex >= 0) {
            currentList[existingIndex] = progress
        } else {
            currentList.add(progress)
        }
        
        _progressCache.value = currentList
        saveProgressToStorage()
    }
    
    suspend fun updateProgress(progress: ReadingProgress) {
        saveProgress(progress)
    }
    
    suspend fun updateReadingProgress(
        userId: Int,
        kitabId: Int,
        currentPage: Int,
        totalPages: Int,
        position: Long = 0L
    ) {
        val existingProgress = getProgress(userId, kitabId)
        
        if (existingProgress != null) {
            existingProgress.updateProgress(currentPage, totalPages)
            existingProgress.lastReadPosition = position
            updateProgress(existingProgress)
        } else {
            val newProgress = ReadingProgress(
                userId = userId,
                kitabId = kitabId,
                lastPageRead = currentPage,
                totalPages = totalPages,
                lastReadPosition = position
            )
            newProgress.updateProgress(currentPage, totalPages)
            saveProgress(newProgress)
        }
    }
    
    suspend fun addReadingTime(userId: Int, kitabId: Int, minutes: Int) {
        val progress = getProgress(userId, kitabId)
        progress?.let {
            it.readingTimeMinutes += minutes
            updateProgress(it)
        }
    }
    
    suspend fun deleteProgress(userId: Int, kitabId: Int) {
        val currentList = _progressCache.value.toMutableList()
        currentList.removeAll { it.userId == userId && it.kitabId == kitabId }
        _progressCache.value = currentList
        saveProgressToStorage()
    }
    
    fun getTopProgressBooks(userId: Int, limit: Int = 5): Flow<List<ReadingProgress>> {
        return _progressCache.map { progress ->
            progress.filter { it.userId == userId }
                .sortedByDescending { it.progressPercentage }
                .take(limit)
        }
    }
    
    suspend fun markAsCompleted(userId: Int, kitabId: Int) {
        val progress = getProgress(userId, kitabId)
        progress?.let {
            it.isCompleted = true
            it.completedAt = System.currentTimeMillis()
            it.progressPercentage = 100f
            updateProgress(it)
        }
    }
}

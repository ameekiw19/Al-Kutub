package com.example.al_kutub.ui.viewmodel

import androidx.lifecycle.ViewModel
import androidx.lifecycle.viewModelScope
import com.example.al_kutub.data.repository.ReadingProgressRepositorySimple
import com.example.al_kutub.model.ReadingProgress
import com.example.al_kutub.utils.SessionManager
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.launch
import javax.inject.Inject

@HiltViewModel
class ReadingProgressViewModel @Inject constructor(
    private val readingProgressRepository: ReadingProgressRepositorySimple,
    private val sessionManager: SessionManager
) : ViewModel() {
    
    private val _uiState = MutableStateFlow(ReadingProgressUiState())
    val uiState: StateFlow<ReadingProgressUiState> = _uiState.asStateFlow()
    
    private val _currentlyReading = MutableStateFlow<List<ReadingProgress>>(emptyList())
    val currentlyReading: StateFlow<List<ReadingProgress>> = _currentlyReading.asStateFlow()
    
    private val _completedBooks = MutableStateFlow<List<ReadingProgress>>(emptyList())
    val completedBooks: StateFlow<List<ReadingProgress>> = _completedBooks.asStateFlow()
    
    private val _allProgress = MutableStateFlow<List<ReadingProgress>>(emptyList())
    val allProgress: StateFlow<List<ReadingProgress>> = _allProgress.asStateFlow()
    
    init {
        loadReadingProgress()
    }
    
    private fun loadReadingProgress() {
        val userId = sessionManager.getUserId() ?: return
        
        viewModelScope.launch {
            try {
                _uiState.value = _uiState.value.copy(isLoading = true)
                
                // Load currently reading books
                readingProgressRepository.getCurrentlyReading(userId).collect { books ->
                    _currentlyReading.value = books
                }
                
                // Load completed books
                readingProgressRepository.getCompletedBooks(userId).collect { books ->
                    _completedBooks.value = books
                }
                
                // Load all progress
                readingProgressRepository.getAllProgress(userId).collect { progress ->
                    _allProgress.value = progress
                }
                
                // Load statistics
                val currentlyReadingCount = readingProgressRepository.getCurrentlyReadingCount(userId)
                val completedBooksCount = readingProgressRepository.getCompletedBooksCount(userId)
                val totalReadingTime = readingProgressRepository.getTotalReadingTime(userId)
                
                _uiState.value = _uiState.value.copy(
                    isLoading = false,
                    currentlyReadingCount = currentlyReadingCount,
                    completedBooksCount = completedBooksCount,
                    totalReadingTimeMinutes = totalReadingTime
                )
                
            } catch (e: Exception) {
                _uiState.value = _uiState.value.copy(
                    isLoading = false,
                    error = e.message
                )
            }
        }
    }
    
    fun updateReadingProgress(
        kitabId: Int,
        currentPage: Int,
        totalPages: Int,
        position: Long = 0L
    ) {
        val userId = sessionManager.getUserId() ?: return
        
        viewModelScope.launch {
            try {
                readingProgressRepository.updateReadingProgress(
                    userId = userId,
                    kitabId = kitabId,
                    currentPage = currentPage,
                    totalPages = totalPages,
                    position = position
                )
            } catch (e: Exception) {
                _uiState.value = _uiState.value.copy(error = e.message)
            }
        }
    }
    
    fun markAsCompleted(kitabId: Int) {
        val userId = sessionManager.getUserId() ?: return
        
        viewModelScope.launch {
            try {
                readingProgressRepository.markAsCompleted(userId, kitabId)
                loadReadingProgress() // Refresh data
            } catch (e: Exception) {
                _uiState.value = _uiState.value.copy(error = e.message)
            }
        }
    }
    
    fun deleteProgress(kitabId: Int) {
        val userId = sessionManager.getUserId() ?: return
        
        viewModelScope.launch {
            try {
                readingProgressRepository.deleteProgress(userId, kitabId)
                loadReadingProgress() // Refresh data
            } catch (e: Exception) {
                _uiState.value = _uiState.value.copy(error = e.message)
            }
        }
    }
    
    fun addReadingTime(kitabId: Int, minutes: Int) {
        val userId = sessionManager.getUserId() ?: return
        
        viewModelScope.launch {
            try {
                readingProgressRepository.addReadingTime(userId, kitabId, minutes)
            } catch (e: Exception) {
                _uiState.value = _uiState.value.copy(error = e.message)
            }
        }
    }
    
    fun clearError() {
        _uiState.value = _uiState.value.copy(error = null)
    }
}

data class ReadingProgressUiState(
    val isLoading: Boolean = false,
    val currentlyReadingCount: Int = 0,
    val completedBooksCount: Int = 0,
    val totalReadingTimeMinutes: Int = 0,
    val error: String? = null
) {
    val totalReadingTimeFormatted: String
        get() = when {
            totalReadingTimeMinutes < 60 -> "${totalReadingTimeMinutes} menit"
            totalReadingTimeMinutes < 1440 -> "${totalReadingTimeMinutes / 60} jam ${totalReadingTimeMinutes % 60} menit"
            else -> "${totalReadingTimeMinutes / 1440} hari ${(totalReadingTimeMinutes % 1440) / 60} jam"
        }
}
